.idea/
*.iml
*.iws
*.ipr

# ── IDE — Eclipse ────────────────────────────────────────────────────────────
.classpath
.project
.settings/
bin/

# ── IDE — VS Code ────────────────────────────────────────────────────────────
.vscode/

# ── OS junk ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Secrets / local config ───────────────────────────────────────────────────
*.env
.env.*
local.properties
gradle-local.properties
crowdin.credentials

# ── Test & coverage artefacts ────────────────────────────────────────────────
*.exec
*.class

